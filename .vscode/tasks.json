{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "编译当前 C 文件",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-Wall",
                "-fexec-charset=GBK",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Ctrl+Shift+B 编译当前 .c 文件"
        },
        {
            "label": "编译并运行当前文件",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-Wall",
                "-fexec-charset=GBK",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "编译并运行当前文件"
        }
    ]
}
