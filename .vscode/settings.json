{
    // ===== 文件编码 =====
    "files.encoding": "utf8",
    "files.autoGuessEncoding": false,

    // ===== 终端配置 =====
    "terminal.integrated.defaultProfile.windows": "UCRT64 (MSYS2)",
    "terminal.integrated.profiles.windows": {
        "UCRT64 (MSYS2)": {
            "path": "C:/msys64/usr/bin/bash.exe",
            "args": ["--login", "-i"],
            "env": {
                "MSYSTEM": "UCRT64",
                "CHERE_INVOKING": "1"
            }
        }
    },

    // ===== Python 配置 =====
    "python.defaultInterpreterPath": "C:/Users/19839/AppData/Local/Programs/Python/Python312/python.exe",

    // ===== Code Runner =====
    "code-runner.runInTerminal": true,
    "code-runner.fileDirectoryAsCwd": true,
    "code-runner.saveFileBeforeRun": true,
    "code-runner.clearPreviousOutput": true,
    "code-runner.executorMap": {
        "c": "gcc -Wall -fexec-charset=GBK $fileName -o $fileNameWithoutExt && ./$fileNameWithoutExt",
        "cpp": "g++ -Wall -fexec-charset=GBK $fileName -o $fileNameWithoutExt && ./$fileNameWithoutExt",
        "python": "C:/Users/19839/AppData/Local/Programs/Python/Python312/python.exe"
    },
    "code-runner.executorMapByGlob": {
        "*.py": "C:/Users/19839/AppData/Local/Programs/Python/Python312/python.exe $fullFileName"
    },
    "code-runner.languageIdToFileExtensionMap": {
        "bat": ".bat",
        "powershell": ".ps1",
        "typescript": ".ts"
    },

    // ===== 编辑器优化 =====
    "editor.minimap.enabled": false,
    "editor.fontSize": 16,
    "editor.tabSize": 4,
    "editor.renderWhitespace": "boundary",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true
}
